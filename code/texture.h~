#define STB_IMAGE_IMPLEMENTATION

#ifndef TEXTURE_H
#define TEXTURE_H

#include <glad/glad.h>
#include <stb_image.h>
#include <cstdio>

struct texture
{
  unsigned int texName;
  unsigned char* texData;
};
  
void texture_init(texture* tex, unsigned int texname, unsigned char* texdata)
  {
    tex->texName = texname;
    tex->texData = texdata;
  };

void texture_gen(texture* tex)
{
  glGenTextures(1, tex->&texName);
  glBindTexture(GL_TEXTURE_2D, tex->texName);

  glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_S, GL_REPEAT);
  glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_T, GL_REPEAT);
  glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MIN_FILTER, GL_LINEAR_MIPMAP_LINEAR);
  glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MAG_FILTER, GL_LINEAR);

};
void load_texture(texture* tex, char texLocation[])
{
  int width, height, nrChannels;
  tex->texData = stbi_load(texLocation, &width, &height, &nrChannels, 0);
  if (tex->texData)
    {
      glTexImage2D(GL_TEXTURE_2D, 0, GL_RGB, width, height, 0, GL_RGBA, GL_UNSIGNED_BYTE, tex->texData);
      glGenerateMipmap(GL_TEXTURE_2D);
    }
  else
    {
      printf("failed to load texture\n");
    }
  stbi_image_free(tex->texData);
};

void bind_texture(texture* tex)
{
  glBindTexture(GL_TEXTURE_2D, tex->texName);
};

#endif
